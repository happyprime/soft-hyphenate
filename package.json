{
  "name": "soft-hyphenate",
  "version": "0.0.1",
  "description": "Maintain a library of hyphenation suggestions for long words used throughout your site.",
  "author": "Happy Prime",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "comments",
    "wordpress"
  ],
  "homepage": "https://github.com/happyprime/soft-hyphenate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/happyprime/soft-hyphenate.git"
  },
  "bugs": {
    "url": "https://github.com/happyprime/soft-hyphenate/issues"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "devDependencies": {
    "@babel/core": "^7.26.7",
    "@babel/plugin-transform-runtime": "^7.25.9",
    "@babel/preset-env": "^7.26.7",
    "@happyprime/eslint-config": "^0.0.13",
    "@wordpress/browserslist-config": "^6.17.0",
    "@wordpress/npm-package-json-lint-config": "^5.17.0",
    "babel-loader": "^9.2.1",
    "npm-package-json-lint": "^8.0.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  },
  "scripts": {
    "build": "webpack --mode production",
    "start": "webpack --mode development --watch",
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "lint:package": "node ./node_modules/npm-package-json-lint/dist/cli.js ./"
  },
  "browserslist": [
    "extends @wordpress/browserslist-config"
  ],
  "npmpackagejsonlint": {
    "extends": "@wordpress/npm-package-json-lint-config"
  }
}
